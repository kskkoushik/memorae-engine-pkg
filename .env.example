# --- LLM (OpenRouter via LangChain ChatOpenRouter) ---
OPENROUTER_API_KEY=sk-or-v1-your-key-here
MEMORAE_LLM=1
MEMORAE_LLM_MODEL=moonshotai/kimi-k2-thinking

# --- RAG (ChromaDB + OpenRouter embeddings) ---
MEMORAE_RAG=1
MEMORAE_EMBED_MODEL=openai/text-embedding-3-small
CHROMA_PERSIST_DIR=./data/chroma
MEMORAE_RAG_TOP_K=60

# --- Data / scenario ---
MEMORAE_EVENTS=./memorae_mock_events.json
MEMORAE_NOW=2026-04-13T03:00:00Z
